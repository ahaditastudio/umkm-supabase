# ============================================================
# KasFlow — Environment Variables
# Copy this file to .env.local and fill in the values.
# ============================================================

# ── Supabase (REQUIRED) ─────────────────────────────────────
# Project URL from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key from Supabase Dashboard → Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service Role key — used by server-side API routes only (NEVER expose to client)
# Found in Supabase Dashboard → Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── App URL (required for OAuth callbacks) ───────────────────
# Base URL of your deployed app (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── TikTok Shop Integration (OPTIONAL) ──────────────────────
# Only needed if you use the marketplace/TikTok Shop integration.
# Get these from TikTok Shop Open Platform → App Management
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
